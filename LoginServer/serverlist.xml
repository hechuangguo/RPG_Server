<?xml version="1.0" encoding="UTF-8"?>
<!--
  serverlist.xml — LoginServer 游戏区列表（玩家选区 UI）

  职责：登记各游戏类型下可登录区服的显示名、入口 IP 与 Super 端口。
  读取方：LoginServer 启动时只读加载至 ZoneInfoStore 内存。
  修改后需重启 LoginServer 生效。
-->
<ServerList>
    <!-- zoneId + gameType 联合唯一；enabled=0 表示维护中（仍下发，客户端置灰） -->
    <Zone zoneId="1" gameType="0" name="RPG一区"
          ip="127.0.0.1" superPort="9000" enabled="1" maxOnline="2000"/>
</ServerList>
