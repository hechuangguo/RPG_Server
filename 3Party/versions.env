# ============================================================================
# 3Party 依赖版本清单（由 download_and_build.sh 自动读取）
# ============================================================================
# 约定：
#   - 修改版本号后运行 autoinit.sh 即可自动下载并重新编译
#   - URL 中的 ${VAR} 由 download_and_build.sh 通过 source 本文件后动态展开
#   - 更新版本时需同步修改 VERSION 变量和对应的 URL（如果源码包命名不一致）
# ============================================================================

# Lua 脚本引擎：轻量级嵌入式解释器，用于游戏逻辑脚本
# 注意：编译时使用 -fPIC 生成位置无关代码，编译为静态库 liblua.a
LUA_VERSION=5.4.7

# tinyxml2：轻量级 XML 解析库，用于解析 config.xml / server_info.xml
# 注意：BUILD_SHARED_LIBS=OFF 编译为静态库，避免运行时依赖
TINYXML2_VERSION=10.0.0

# MariaDB Connector/C：MySQL/MariaDB 客户端库，用于数据库连接
# 注意：仅编译客户端（--target mariadbclient），不编译完整的 MariaDB 服务器
#       libmariadbclient / libmariadb 新旧命名兼容处理已由脚本自动完成
MARIADB_CONNECTOR_VERSION=3.3.10

# ---- 下载地址（修改版本号时注意同步检查以下 URL 是否有效）----

# Lua 官方 FTP 发布页
LUA_URL=https://www.lua.org/ftp/lua-${LUA_VERSION}.tar.gz

# tinyxml2 GitHub Release 标签页
TINYXML2_URL=https://github.com/leethomason/tinyxml2/archive/refs/tags/${TINYXML2_VERSION}.tar.gz

# MariaDB Connector/C 官方归档站（注意：3.3.10 后路径格式可能变化）
MARIADB_CONNECTOR_URL=https://archive.mariadb.org/connector-c-3.3.10/mariadb-connector-c-3.3.10-src.tar.gz
