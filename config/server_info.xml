<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  server_info.xml  —  单个 SceneServer 进程的地图配置
  ============================================================================

  职责：
    - 描述一个 SceneServer 进程承载哪些地图
    - 每个 Map 节点定义地图 ID、名称、资源文件路径、最大玩家数

  说明：
    - 每个 SceneServer 进程对应一份 server_info.xml
    - 多个 SceneServer 可承载相同或不同的地图实现负载均衡
    - sceneID 必须唯一，用于 SuperServer 路由识别

  地图 ID 约定：
    - 1000 ~ 1999 : 主城 / 新手村
    - 2000 ~ 2999 : 野外地图
    - 3000 ~ 3999 : 副本
    - 4000 ~ 4999 : PvP 战场

  ============================================================================
-->

<SceneServerInfo sceneID="1">   <!-- 场景服务器唯一编号 -->

    <!-- ================================================================= -->
    <!--  地图 1001：新手村                                                 -->
    <!--    新创建角色默认出生地图，应始终分配给场景服务器                     -->
    <!-- ================================================================= -->
    <Map id="1001"
         name="新手村"
         file="map/1001.map"
         maxPlayer="200"/>

    <!-- ================================================================= -->
    <!--  地图 1002：主城                                                   -->
    <!--    核心社交区域，承载人数最多                                      -->
    <!-- ================================================================= -->
    <Map id="1002"
         name="主城"
         file="map/1002.map"
         maxPlayer="500"/>

    <!-- ================================================================= -->
    <!--  地图 2001：迷雾森林  —  低级野外地图                              -->
    <!-- ================================================================= -->
    <Map id="2001"
         name="迷雾森林"
         file="map/2001.map"
         maxPlayer="100"/>

    <!-- ================================================================= -->
    <!--  地图 2002：荒漠要塞  —  中级野外地图                              -->
    <!-- ================================================================= -->
    <Map id="2002"
         name="荒漠要塞"
         file="map/2002.map"
         maxPlayer="100"/>

</SceneServerInfo>
