<?xml version="1.0" encoding="UTF-8"?>
<!--
  extern_login.xml — LoginServer 独立部署配置（与 ZoneServer/extern_zone.xml 同级）

  职责：
    - ClientListen：玩家登录（C2S_LOGIN_REQ，默认 9010）
    - GameZoneListen（RegisterListen）：SuperServer 游戏区转发入口（默认 19010）
    - Database：账号库 rpg_login（GameUser/ZoneInfo），与游戏区 rpg_game 分离

  独立进程，不向 Super 注册；仅 SuperServer 经 loginserverlist.xml 连接 GameZoneListen。
  游戏区列表见 ServerList 节点指向的 serverlist.xml（客户端 C2S_ZONE_LIST_REQ）。
  修改后需重启 LoginServer 生效。
-->
<ExternServer>
    <!-- 玩家登录入口（客户端连接） -->
    <ClientListen ip="0.0.0.0" port="9010"/>
    <!-- 游戏区 Gateway 网关注册/心跳（非玩家口） -->
    <RegisterListen ip="0.0.0.0" port="19010"/>
    <!-- 游戏区列表（启动加载至内存，供客户端选区） -->
    <ServerList path="LoginServer/serverlist.xml"/>
    <LogPath>logs/login.log</LogPath>
    <!-- 账号库：仅登录服使用 -->
    <Database host="127.0.0.1" port="3306" user="rpg_table" pass="rpg_table" name="rpg_login"/>
</ExternServer>
