<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  config.xml  —  RPG Server 全局配置文件
  ============================================================================

  职责：
    - 数据库连接参数（MySQL 主机/端口/用户/密码/库名）
    - SuperServer 的监听 IP 和端口（所有子服务器据此连接）
    - 外联服 Logger/Global/Zone 地址见根目录 loginserverlist.xml（游戏区客户端配置）
    - 各服务器日志输出路径

  使用说明：
    - 本文件由所有服务器进程在启动时读取
    - Database 段由 RecordServer 直连 MySQL；SuperServer 启动期亦只读加载 ServerList
    - SuperServer 段定义了中心服务器的监听地址，所有子服务器通过 TcpClient 连接
    - Session/Record/AOI/Scene/Gateway 的端口/对端地址来自 DB 的 ServerList 表
      （init.sql），由 SuperServer 启动加载并在子服启动拉取时下发，不再写在本文件
    - 外联 Logger/Global/Zone 由根目录 loginserverlist.xml 配置（游戏区出站连接）
    - LogPaths 定义了各区内进程的本地日志路径

  修改后需重启所有服务器生效。

  ============================================================================
-->

<ServerConfig>

    <!-- ================================================================ -->
    <!--  数据库配置段                                                    -->
    <!--  用途：提供 MySQL 数据库连接参数，仅由 RecordServer 直接连接      -->
    <!--        其他服务器通过 RecordServer 代理进行数据读写               -->
    <!--  host：MySQL 主机地址（IP 或域名）                               -->
    <!--  port：MySQL 端口号，默认 3306                                    -->
    <!--  user：MySQL 登录用户名                                          -->
    <!--  pass：MySQL 登录密码（生产环境部署时必须修改）                    -->
    <!--  name：数据库名称，需与 tables/init.sql 中库名一致                -->
    <!-- ================================================================ -->
    <Database host="127.0.0.1" port="3306" user="rpg_table" pass="rpg_table" name="rpg_game"/>

    <!-- ================================================================ -->
    <!--  SuperServer 配置                                                -->
    <!--  用途：定义中心服务器的监听地址                                   -->
    <!--        所有子服务器（Session/Record/AOI/Scene/Gateway 等）        -->
    <!--        启动后均通过 TcpClient 连接到此地址进行内部通信              -->
    <!--  ip：监听 IP（通常为本机回环或内网 IP）                            -->
    <!--  port：监听端口，子服务器连接的目标端口                            -->
    <!-- ================================================================ -->
    <SuperServer ip="127.0.0.1" port="9000"/>

    <!-- 本游戏区身份：Super/Gateway 向 LoginServer 上报区状态时使用；须与 serverlist.xml zoneId 一致 -->
    <Zone zoneId="1" gameType="0"/>

    <!-- ================================================================ -->
    <!--  各服务器内部监听端口配置                                         -->
    <!--  说明：Session/Record/AOI/Scene/Gateway 端口已迁移至 DB 的         -->
    <!--        ServerList 表（init.sql），由 SuperServer 启动只读加载并在    -->
    <!--        子服启动拉取时下发；此处不再配置这 5 个服务器端口。           -->
    <!--        Logger/Global/Zone 为可选外联服，见 loginserverlist.xml。      -->
    <!-- ================================================================ -->

    <!-- ================================================================ -->
    <!--  日志输出路径配置                                                 -->
    <!--  用途：按服务器名称映射到日志文件路径                              -->
    <!--        LoggerServer 接收远程日志并写入；路径相对进程工作目录        -->
    <!--  实时日志为 logs/xxx.log；跨小时归档为 xxx.log.YYYYMMDD-HH        -->
    <!-- ================================================================ -->
    <LogPaths>
        <!-- SuperServer 日志 -->
        <SuperServer>logs/super.log</SuperServer>
        <!-- SessionServer 日志 -->
        <SessionServer>logs/session.log</SessionServer>
        <!-- RecordServer 日志 -->
        <RecordServer>logs/record.log</RecordServer>
        <!-- AOIServer 日志 -->
        <AOIServer>logs/aoi.log</AOIServer>
        <!-- SceneServer 日志 -->
        <SceneServer>logs/scene.log</SceneServer>
        <!-- GatewayServer 日志 -->
        <GatewayServer>logs/gateway.log</GatewayServer>
        <!-- LoggerServer 自身日志 -->
        <LoggerServer>logs/logger.log</LoggerServer>
        <!-- GlobalServer 日志 -->
        <GlobalServer>logs/global.log</GlobalServer>
        <!-- ZoneServer 日志 -->
        <ZoneServer>logs/zone.log</ZoneServer>
    </LogPaths>

</ServerConfig>
