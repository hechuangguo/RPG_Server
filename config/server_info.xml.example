<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  server_info.xml  —  单个 SceneServer 进程的地图配置
  ============================================================================

  职责：
    - 描述一个 SceneServer 进程承载哪些地图（仅 mapId）
    - 地图名称、人数上限、版本等元数据来自 Common/DataDoc/map.xlsx → database/map_config.lua
    - 几何数据来自 Common/map/{mapId}/

  使用说明：
    - 每个 SceneServer 进程对应一份 server_info.xml（通过启动参数指定路径）
    - 多个 SceneServer 可承载相同或不同的地图以实现负载均衡
    - sceneID 必须唯一，用于 SuperServer 进行路由识别和消息转发

  地图 ID 编号约定：
    - 1000 ~ 1999 : 主城 / 新手村（安全区域，无战斗）
    - 2000 ~ 2999 : 野外地图（普通战斗区域）
    - 3000 ~ 3999 : 副本（组队挑战区域，有进入次数限制）
    - 4000 ~ 4999 : PvP 战场（玩家对战区域）

  Map 属性说明：
    - id        : 地图唯一编号，全局不可重复（必填）
    - name      : 可选覆盖显示名；默认读 map_config
    - maxPlayer : 可选覆盖人数上限；默认读 map_config

  ============================================================================
-->

<!-- sceneID：本 SceneServer 进程唯一编号，SuperServer 据此区分实例 -->
<SceneServerInfo sceneID="1">

    <Map id="1001" maxPlayer="200"/>

    <Map id="1002" maxPlayer="500"/>

    <Map id="1003" maxPlayer="100"/>

</SceneServerInfo>
