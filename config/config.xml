<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  config.xml  —  RPG Server 全局配置文件
  ============================================================================

  职责：
    - 数据库连接参数（MySQL 主机/端口/用户/密码/库名）
    - SuperServer 的监听 IP 和端口（所有子服务器据此连接）
    - 各内部服务器的监听端口（按 server_info.xml 中 sceneID 可扩展多实例）
    - 各服务器日志输出路径

  修改后需重启所有服务器生效。

  ============================================================================
-->

<ServerConfig>

    <!-- ================================================================ -->
    <!--  数据库配置（仅 RecordServer 直接连接 MySQL）                     -->
    <!-- ================================================================ -->
    <Database
        host="127.0.0.1"         <!-- MySQL 主机地址 -->
        port="3306"               <!-- MySQL 端口 -->
        user="root"               <!-- MySQL 用户名 -->
        pass="your_password"      <!-- MySQL 密码（部署时修改） -->
        name="rpg_game"           <!-- 数据库名称 -->
    />

    <!-- ================================================================ -->
    <!--  SuperServer  —  所有子服务器启动后通过 TcpClient 连接此地址      -->
    <!-- ================================================================ -->
    <SuperServer
        ip="127.0.0.1"    <!-- 监听 IP -->
        port="9000"       <!-- 监听端口 -->
    />

    <!-- ================================================================ -->
    <!--  各服务器内部监听端口（子服务器启动时 bind 的端口）              -->
    <!-- ================================================================ -->
    <SessionServer port="9001"/>   <!-- 社会关系 / 离线数据 -->
    <RecordServer  port="9002"/>   <!-- 数据库读写 -->
    <AOIServer     port="9003"/>   <!-- 视野管理 / 9宫格 -->
    <SceneServer   port="9004"/>   <!-- 场景逻辑 / Lua 脚本 -->
    <GatewayServer port="9005"/>   <!-- 客户端接入网关 -->
    <LoggerServer  port="9006"/>   <!-- 日志收集 -->
    <GlobalServer  port="9007"/>   <!-- 全区数据（可选） -->
    <ZoneServer    port="9008"/>   <!-- 跨区转发（可选） -->

    <!-- ================================================================ -->
    <!--  日志输出路径（按服务器名称映射到文件路径）                       -->
    <!--  由 LoggerServer 负责接收远程日志并写入这些文件                  -->
    <!-- ================================================================ -->
    <LogPaths>
        <SuperServer>logs/super.log</SuperServer>
        <SessionServer>logs/session.log</SessionServer>
        <RecordServer>logs/record.log</RecordServer>
        <AOIServer>logs/aoi.log</AOIServer>
        <SceneServer>logs/scene.log</SceneServer>
        <GatewayServer>logs/gateway.log</GatewayServer>
        <LoggerServer>logs/logger.log</LoggerServer>
        <GlobalServer>logs/global.log</GlobalServer>
        <ZoneServer>logs/zone.log</ZoneServer>
    </LogPaths>

</ServerConfig>
