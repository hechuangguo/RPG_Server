# Build output
.build/

# Logs（运行期输出，config.xml / RunServer.sh 写入 logs/）
logs/

# Cache
.cache/
__pycache__/
*.pyc
*.pyo
scripts/pb/*_pb2.py

# Runtime PID files
run/

# 用户目录下本地 MySQL 数据（setup 时若无法 sudo systemctl 则使用）
.mysql/

LoginServer/serverlist.xml

# Protobuf C++ 生成物（scripts/gen_proto.sh 自动生成；README.md 保留）
Protobuf/*.pb.h
Protobuf/*.pb.cc

# TLS 私钥与 CA（执行 gen_tls_certs.sh 生成；ca.crt/server.crt 可分发）
config/tls/*.key
config/tls/ca.key

# 各服务器编译产物（可执行文件，与目录同名）
SuperServer/SuperServer
SessionServer/SessionServer
RecordServer/RecordServer
AOIServer/AOIServer
SceneServer/SceneServer
GatewayServer/GatewayServer
LoggerServer/LoggerServer
GlobalServer/GlobalServer
ZoneServer/ZoneServer
LoginServer/LoginServer

LoginServer/serverlist.xml