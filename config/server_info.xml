<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  server_info.xml  —  单个 SceneServer 进程的地图配置
  ============================================================================

  职责：
    - 描述一个 SceneServer 进程承载哪些地图
    - 每个 Map 节点定义地图 ID、名称、资源文件路径、最大承载用户数

  使用说明：
    - 每个 SceneServer 进程对应一份 server_info.xml（通过启动参数指定路径）
    - 多个 SceneServer 可承载相同或不同的地图以实现负载均衡
    - sceneID 必须唯一，用于 SuperServer 进行路由识别和消息转发

  地图 ID 编号约定：
    - 1000 ~ 1999 : 主城 / 新手村（安全区域，无战斗）
    - 2000 ~ 2999 : 野外地图（普通战斗区域）
    - 3000 ~ 3999 : 副本（组队挑战区域，有进入次数限制）
    - 4000 ~ 4999 : PvP 战场（玩家对战区域）

  Map 属性说明：
    - id        : 地图唯一编号，全局不可重复
    - name      : 地图显示名称
    - file      : 地图资源相对路径（.map），地形/碰撞/传送点等
    - maxPlayer : 该地图允许同时在线的最大用户数

  ============================================================================
-->

<!-- sceneID：本 SceneServer 进程唯一编号，SuperServer 据此区分实例 -->
<SceneServerInfo sceneID="1">

    <!-- ================================================================= -->
    <!--  地图 1001：新手村                                                 -->
    <!--    用途：新创建用户的默认出生地图                                   -->
    <!--          安全区域，不允许 PK 战斗                                   -->
    <!--    maxPlayer：最大同时在线 200 人                                  -->
    <!-- ================================================================= -->
    <!--    出生点：与 sdk/util/LoginSpawnConfig.h DEFAULT_NEWBIE_SPAWN_* 对齐       -->
    <!--          Record 创角 SQL 当前读常量；后续可改为解析 Spawn 属性              -->
    <Map id="1001" name="新手村" file="map/1001.map" maxPlayer="200"
         spawnX="100" spawnY="0" spawnZ="100"/>

    <!-- ================================================================= -->
    <!--  地图 1002：主城                                                   -->
    <!--    用途：核心社交与交易区域                                         -->
    <!--          建议分配给高性能 SceneServer；安全区，商店/拍卖行等         -->
    <!--    maxPlayer：最大同时在线 500 人（核心区域需要较高容量）              -->
    <!-- ================================================================= -->
    <Map id="1002" name="主城" file="map/1002.map" maxPlayer="500"/>

    <!-- ================================================================= -->
    <!--  地图 2001：迷雾森林 — 低级野外地图                                  -->
    <!--    用途：1~20 级练级区域，低级怪物与采集点                           -->
    <!--    maxPlayer：最大同时在线 100 人                                  -->
    <!-- ================================================================= -->
    <Map id="2001" name="迷雾森林" file="map/2001.map" maxPlayer="100"/>

    <!-- ================================================================= -->
    <!--  地图 2002：荒漠要塞 — 中级野外地图                                  -->
    <!--    用途：20~40 级练级区域，中级怪物与精英怪                          -->
    <!--    maxPlayer：最大同时在线 100 人                                  -->
    <!-- ================================================================= -->
    <Map id="2002" name="荒漠要塞" file="map/2002.map" maxPlayer="100"/>

</SceneServerInfo>
