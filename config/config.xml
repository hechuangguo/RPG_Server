<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  config.xml  —  RPG Server 全局配置文件
  ============================================================================

  职责：
    - 数据库连接参数（MySQL 主机/端口/用户/密码/库名）
    - SuperServer 的监听 IP 和端口（所有子服务器据此连接）
    - 各内部服务器的监听端口（按 server_info.xml 中 sceneID 可扩展多实例）
    - 各服务器日志输出路径

  使用说明：
    - 本文件由所有服务器进程在启动时读取
    - Database 段仅 RecordServer 直接使用，用于连接 MySQL
    - SuperServer 段定义了中心服务器的监听地址，所有子服务器通过 TcpClient 连接
    - 各服务器端口段定义了子服务器本地绑定的监听端口
    - LogPaths 定义了日志文件的输出路径，由 LoggerServer 统一写入

  修改后需重启所有服务器生效。

  ============================================================================
-->

<ServerConfig>

    <!-- ================================================================ -->
    <!--  数据库配置段                                                    -->
    <!--  用途：提供 MySQL 数据库连接参数，仅由 RecordServer 直接连接      -->
    <!--        其他服务器通过 RecordServer 代理进行数据读写               -->
    <!--  host：MySQL 主机地址（IP 或域名）                               -->
    <!--  port：MySQL 端口号，默认 3306                                    -->
    <!--  user：MySQL 登录用户名                                          -->
    <!--  pass：MySQL 登录密码（生产环境部署时必须修改）                    -->
    <!--  name：数据库名称，需与 tables/init.sql 中库名一致                -->
    <!-- ================================================================ -->
    <Database host="127.0.0.1" port="3306" user="root" pass="your_password" name="rpg_game"/>

    <!-- ================================================================ -->
    <!--  SuperServer 配置                                                -->
    <!--  用途：定义中心服务器的监听地址                                   -->
    <!--        所有子服务器（Session/Record/AOI/Scene/Gateway 等）        -->
    <!--        启动后均通过 TcpClient 连接到此地址进行内部通信              -->
    <!--  ip：监听 IP（通常为本机回环或内网 IP）                            -->
    <!--  port：监听端口，子服务器连接的目标端口                            -->
    <!-- ================================================================ -->
    <SuperServer ip="127.0.0.1" port="9000"/>

    <!-- ================================================================ -->
    <!--  各服务器内部监听端口配置                                         -->
    <!--  用途：定义每个子服务器启动时本地 bind 的端口                      -->
    <!--        GatewayServer 对外暴露给客户端，其他端口仅内网使用           -->
    <!-- ================================================================ -->
    <!-- SessionServer：社会关系/离线数据，好友、邮件等社交功能 -->
    <SessionServer port="9001"/>
    <!-- RecordServer：数据库读写代理，唯一直连 MySQL，负责持久化 -->
    <RecordServer port="9002"/>
    <!-- AOIServer：兴趣范围（AOI），9 宫格视野管理 -->
    <AOIServer port="9003"/>
    <!-- SceneServer：场景逻辑，Lua 驱动战斗/NPC 等 -->
    <SceneServer port="9004"/>
    <!-- GatewayServer：客户端接入网关，连接管理与消息转发 -->
    <GatewayServer port="9005"/>
    <!-- LoggerServer：集中收集各服远程日志并写文件 -->
    <LoggerServer port="9006"/>
    <!-- GlobalServer：全区数据（可选），排行榜、全服公告等 -->
    <GlobalServer port="9007"/>
    <!-- ZoneServer：跨区转发（可选），多区架构消息路由 -->
    <ZoneServer port="9008"/>

    <!-- ================================================================ -->
    <!--  日志输出路径配置                                                 -->
    <!--  用途：按服务器名称映射到日志文件路径                              -->
    <!--        LoggerServer 接收远程日志并写入；路径相对进程工作目录        -->
    <!--  实时日志为 logs/xxx.log；跨小时归档为 xxx.log.YYYYMMDD-HH        -->
    <!-- ================================================================ -->
    <LogPaths>
        <!-- SuperServer 日志 -->
        <SuperServer>logs/super.log</SuperServer>
        <!-- SessionServer 日志 -->
        <SessionServer>logs/session.log</SessionServer>
        <!-- RecordServer 日志 -->
        <RecordServer>logs/record.log</RecordServer>
        <!-- AOIServer 日志 -->
        <AOIServer>logs/aoi.log</AOIServer>
        <!-- SceneServer 日志 -->
        <SceneServer>logs/scene.log</SceneServer>
        <!-- GatewayServer 日志 -->
        <GatewayServer>logs/gateway.log</GatewayServer>
        <!-- LoggerServer 自身日志 -->
        <LoggerServer>logs/logger.log</LoggerServer>
        <!-- GlobalServer 日志 -->
        <GlobalServer>logs/global.log</GlobalServer>
        <!-- ZoneServer 日志 -->
        <ZoneServer>logs/zone.log</ZoneServer>
    </LogPaths>

</ServerConfig>
