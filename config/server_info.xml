<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  server_info.xml  —  单个 SceneServer 进程的地图配置
  ============================================================================

  职责：
    - 描述一个 SceneServer 进程承载哪些地图
    - 每个 Map 节点定义地图 ID、名称、资源文件路径、最大承载用户数

  使用说明：
    - 每个 SceneServer 进程对应一份 server_info.xml（通过启动参数指定路径）
    - 多个 SceneServer 可承载相同或不同的地图以实现负载均衡
    - sceneID 必须唯一，用于 SuperServer 进行路由识别和消息转发

  地图 ID 编号约定：
    - 1000 ~ 1999 : 主城 / 新手村（安全区域，无战斗）
    - 2000 ~ 2999 : 野外地图（普通战斗区域）
    - 3000 ~ 3999 : 副本（组队挑战区域，有进入次数限制）
    - 4000 ~ 4999 : PvP 战场（玩家对战区域）

  Map 字段说明：
    - id         : 地图唯一编号，全局不可重复，用于服务器间路由和用户位置标识
    - name       : 地图显示名称，用于日志输出和调试信息
    - file       : 地图资源文件相对路径（.map 二进制文件），包含地形/碰撞/传送点等数据
    - maxPlayer  : 该地图允许同时在线的最大用户数上限，达到上限后拒绝新用户进入

  ============================================================================

-->

<SceneServerInfo sceneID="1">   <!-- 场景服务器唯一编号（sceneID），SuperServer据此区分不同SceneServer实例 -->

    <!-- ================================================================= -->
    <!--  地图 1001：新手村                                                 -->
    <!--    用途：新创建用户的默认出生地图                                   -->
    <!--          安全区域，不允许PK战斗                                     -->
    <!--          应始终分配给某个场景服务器保证可用性                         -->
    <!-- ================================================================= -->
    <Map id="1001"
         name="新手村"
         file="map/1001.map"
         maxPlayer="200"/>   <!-- 最大同时在线200个用户 -->

    <!-- ================================================================= -->
    <!--  地图 1002：主城                                                   -->
    <!--    用途：核心社交与交易区域                                         -->
    <!--          承载人数最多的地图，建议分配给高性能场景服务器               -->
    <!--          安全区，包含NPC商店、拍卖行等设施                           -->
    <!-- ================================================================= -->
    <Map id="1002"
         name="主城"
         file="map/1002.map"
         maxPlayer="500"/>   <!-- 最大同时在线500个用户（核心区域需要较高容量） -->

    <!-- ================================================================= -->
    <!--  地图 2001：迷雾森林  —  低级野外地图                               -->
    <!--    用途：1~20级用户的练级区域                                       -->
    <!--          包含低级怪物和采集点                                        -->
    <!-- ================================================================= -->
    <Map id="2001"
         name="迷雾森林"
         file="map/2001.map"
         maxPlayer="100"/>   <!-- 最大同时在线100个用户 -->

    <!-- ================================================================= -->
    <!--  地图 2002：荒漠要塞  —  中级野外地图                               -->
    <!--    用途：20~40级用户的练级区域                                      -->
    <!--          包含中级怪物和精英怪                                       -->
    <!-- ================================================================= -->
    <Map id="2002"
         name="荒漠要塞"
         file="map/2002.map"
         maxPlayer="100"/>   <!-- 最大同时在线100个用户 -->

</SceneServerInfo>
