<?xml version="1.0" encoding="UTF-8"?>
<!--
  extern_zone.xml — ZoneServer 独立部署配置
  职责：跨区转发 TCP 监听、进程日志。
  外联服不连接游戏区 MySQL；跨区持久化若需要另建独立库。
  游戏区在 loginserverlist.xml 中配置连接本服务 ip/port。
  修改后需重启 ZoneServer 生效。
-->
<ExternServer>
    <Listen ip="0.0.0.0" port="9008"/>
    <LogPath>logs/zone.log</LogPath>
    <!-- TLS：Super 经 mTLS 连接；修改后重启 ZoneServer -->
    <Tls enabled="1"
         cert="config/tls/server.crt"
         key="config/tls/server.key"
         ca="config/tls/ca.crt"
         verifyPeer="1"
         minVersion="1.2"
         cipherSuites="ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384"
         tls13CipherSuites="TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384"/>
</ExternServer>
