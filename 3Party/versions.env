# ============================================================================
# 3Party 依赖版本清单（由 download_and_build.sh / fetch_vendor.sh 读取）
# ============================================================================
# 约定：
#   - vendor/ 目录下的 tar.gz 已纳入 Git；clone 后 ./autoinit.sh 离线编译，不下载
#   - 升级版本：改 VERSION + URL → ./3Party/fetch_vendor.sh → commit vendor/
#   - URL 中的 ${VAR} 由脚本 source 本文件后动态展开
# ============================================================================

# Lua 脚本引擎
LUA_VERSION=5.4.7

# tinyxml2 XML 解析库
TINYXML2_VERSION=10.0.0

# MariaDB Connector/C MySQL 客户端
MARIADB_CONNECTOR_VERSION=3.3.10

# Protocol Buffers（可选 vendor；默认链接系统 /usr/local）
PROTOBUF_VERSION=21.12

# ---- 下载地址（仅供 fetch_vendor.sh / --force 使用）----

LUA_URL=https://www.lua.org/ftp/lua-${LUA_VERSION}.tar.gz

TINYXML2_URL=https://github.com/leethomason/tinyxml2/archive/refs/tags/${TINYXML2_VERSION}.tar.gz
TINYXML2_MIRROR_URLS="https://ghproxy.net/https://github.com/leethomason/tinyxml2/archive/refs/tags/${TINYXML2_VERSION}.tar.gz https://mirror.ghproxy.com/https://github.com/leethomason/tinyxml2/archive/refs/tags/${TINYXML2_VERSION}.tar.gz"

MARIADB_CONNECTOR_URL=https://archive.mariadb.org/connector-c-3.3.10/mariadb-connector-c-3.3.10-src.tar.gz
MARIADB_CONNECTOR_MIRROR_URLS="https://dlm.mariadb.com/2339774/Connector-C/connector-c-3.3.10/mariadb-connector-c-3.3.10-src.tar.gz"
