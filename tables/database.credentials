# RPG 游戏服务器 MySQL 连接信息（与 config/config.xml Database 段一致，区内服默认库）
# 应用账号对 rpg_login / rpg_game / rpg_global 均有权限。
# LoginServer：extern_login.xml name=rpg_login
# GlobalServer：extern_global.xml name=rpg_global
# Database Client：SSL 留空；认证插件为 mysql_native_password（见 create_user_and_db.sql）

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=rpg_game
LOGIN_DB_NAME=rpg_login
GLOBAL_DB_NAME=rpg_global
DB_USER=rpg_table
DB_PASS=rpg_table
