<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  config.xml  —  RPG Server 全局配置文件
  ============================================================================

  职责：
    - 数据库连接参数（MySQL 主机/端口/用户/密码/库名）
    - SuperServer 的监听 IP 和端口（所有子服务器据此连接）
    - 各内部服务器的监听端口（按 server_info.xml 中 sceneID 可扩展多实例）
    - 各服务器日志输出路径

  使用说明：
    - 本文件由所有服务器进程在启动时读取
    - Database 段仅 RecordServer 直接使用，用于连接 MySQL
    - SuperServer 段定义了中心服务器的监听地址，所有子服务器通过 TcpClient 连接
    - 各服务器端口段定义了子服务器本地绑定的监听端口
    - LogPaths 定义了日志文件的输出路径，由 LoggerServer 统一写入

  修改后需重启所有服务器生效。

  ============================================================================
-->

<ServerConfig>

    <!-- ================================================================ -->
    <!--  数据库配置段                                                    -->
    <!--  用途：提供 MySQL 数据库连接参数，仅由 RecordServer 直接连接      -->
    <!--        其他服务器通过 RecordServer 代理进行数据读写               -->
    <!-- ================================================================ -->
    <Database
        host="127.0.0.1"         <!-- MySQL 主机地址（IP或域名） -->
        port="3306"               <!-- MySQL 端口号，默认3306 -->
        user="root"               <!-- MySQL 登录用户名 -->
        pass="your_password"      <!-- MySQL 登录密码（生产环境部署时必须修改） -->
        name="rpg_game"           <!-- 数据库名称，需与 init.sql 中创建的库名一致 -->
    />

    <!-- ================================================================ -->
    <!--  SuperServer 配置                                                -->
    <!--  用途：定义中心服务器的监听地址                                   -->
    <!--        所有子服务器（Session/Record/AOI/Scene/Gateway等）          -->
    <!--        启动后均通过 TcpClient 连接到此地址进行内部通信              -->
    <!-- ================================================================ -->
    <SuperServer
        ip="127.0.0.1"    <!-- 监听 IP 地址（通常绑定本机回环或内网IP） -->
        port="9000"       <!-- 监听端口号，子服务器连接的目标端口 -->
    />

    <!-- ================================================================ -->
    <!--  各服务器内部监听端口配置                                         -->
    <!--  用途：定义每个子服务器启动时本地 bind 的端口                      -->
    <!--        GatewayServer 对外暴露给客户端，其他端口仅内网使用           -->
    <!-- ================================================================ -->
    <SessionServer port="9001"/>   <!-- SessionServer：社会关系/离线数据管理，处理好友、邮件等社交功能 -->
    <RecordServer  port="9002"/>   <!-- RecordServer：数据库读写代理，唯一直接连接MySQL的服务器，负责所有数据持久化 -->
    <AOIServer     port="9003"/>   <!-- AOIServer：兴趣范围管理（AOI），基于9宫格算法管理用户视野范围内的实体列表 -->
    <SceneServer   port="9004"/>   <!-- SceneServer：场景逻辑服务器，运行Lua脚本驱动的游戏逻辑（战斗/NPC/怪物等） -->
    <GatewayServer port="9005"/>   <!-- GatewayServer：客户端接入网关，负责玩家客户端的TCP连接管理、消息转发和会话维持 -->
    <LoggerServer  port="9006"/>   <!-- LoggerServer：日志收集服务器，接收各服务器的远程日志并统一写入文件 -->
    <GlobalServer  port="9007"/>   <!-- GlobalServer：全区数据服务器（可选），处理跨场景的全局数据如排行榜、全局公告等 -->
    <ZoneServer    port="9008"/>   <!-- ZoneServer：跨区转发服务器（可选），用于多区架构下跨区域的消息路由和数据同步 -->

    <!-- ================================================================ -->
    <!--  日志输出路径配置                                                 -->
    <!--  用途：按服务器名称映射到对应的日志文件路径                        -->
    <!--        由 LoggerServer 负责接收远程日志并写入这些文件              -->
    <!--        日志目录相对于程序工作目录                                  -->
    <!-- ================================================================ -->
    <LogPaths>
        <SuperServer>logs/super.log</SuperServer>     <!-- SuperServer 日志文件路径 -->
        <SessionServer>logs/session.log</SessionServer> <!-- SessionServer 日志文件路径 -->
        <RecordServer>logs/record.log</RecordServer>   <!-- RecordServer 日志文件路径 -->
        <AOIServer>logs/aoi.log</AOIServer>             <!-- AOIServer 日志文件路径 -->
        <SceneServer>logs/scene.log</SceneServer>       <!-- SceneServer 日志文件路径 -->
        <GatewayServer>logs/gateway.log</GatewayServer> <!-- GatewayServer 日志文件路径 -->
        <LoggerServer>logs/logger.log</LoggerServer>   <!-- LoggerServer 自身日志文件路径 -->
        <GlobalServer>logs/global.log</GlobalServer>     <!-- GlobalServer 日志文件路径 -->
        <ZoneServer>logs/zone.log</ZoneServer>           <!-- ZoneServer 日志文件路径 -->
    </LogPaths>

</ServerConfig>
